# Telegram
TELEGRAM_BOT_TOKEN=123456789:your_token
TELEGRAM_SOURCE_ID=my_telegram_bot
# Optional: process only one group/chat id. Leave empty for any chat.
TELEGRAM_ALLOWED_CHAT_ID=-1001234567890
TELEGRAM_POLL_TIMEOUT_SECONDS=30
TELEGRAM_POLL_INTERVAL_SECONDS=1.0
TELEGRAM_OFFSET_FILE=./var/offset.txt

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=input_message
RABBITMQ_EXCHANGE=input_messages_exchange
RABBITMQ_EXCHANGE_TYPE=direct
RABBITMQ_QUEUE=input.messages.queue
RABBITMQ_ROUTING_KEY=input.messages
RABBITMQ_HEARTBEAT_SECONDS=60
RABBITMQ_BLOCKED_CONNECTION_TIMEOUT_SECONDS=300

# Storage
FILES_BASE_DIR=./storage
DEFAULT_LANGUAGE=uk

# Logging
# DEBUG logs everything to file + console.
# ERROR logs only technical errors.
LOG_LEVEL=ERROR
# Priority: if LOG_FILE_PATH is set, LOG_DIR and LOG_FILE_NAME are ignored.
LOG_FILE_PATH=
LOG_DIR=./logs
LOG_FILE_NAME=service.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=3
